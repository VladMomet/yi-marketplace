# ====================================================================
# Yí Marketplace — environment configuration
#
# ЛОКАЛЬНО:
#   1. Скопируйте этот файл: cp .env.example .env.local
#   2. Заполните значения
#   3. Запустите npm run dev
#
# VERCEL (продакшн):
#   Зайдите на Vercel → ваш проект → Settings → Environment Variables.
#   Добавьте каждую переменную руками. ВАЖНО: переменные с `NEXT_PUBLIC_`
#   видны клиенту, остальные — только серверу (это безопасно).
# ====================================================================

# === БАЗА ДАННЫХ (PostgreSQL) =======================================
# Локально (Docker):
#   DATABASE_URL=postgresql://yi:password@localhost:5432/yi_marketplace
# Vercel (через Neon — https://neon.tech):
#   DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/yi?sslmode=require
DATABASE_URL=postgresql://yi:password@localhost:5432/yi_marketplace

# === Auth.js =========================================================
# Сгенерируйте: openssl rand -base64 32
# (или используйте любой генератор: https://generate-secret.vercel.app/32)
AUTH_SECRET=replace-me-with-a-random-string-at-least-32-chars-long

# Локально: http://localhost:3000
# На Vercel: https://your-project.vercel.app или ваш реальный домен.
# Если не задано на Vercel — берётся автоматически из VERCEL_URL.
AUTH_URL=http://localhost:3000

# === S3 для фото-референсов (Selectel Object Storage) ===============
# Нужно только для формы подбора с загрузкой фото.
# Если пока не настраиваете — оставьте заглушки, подбор будет падать,
# но всё остальное работает.
S3_ENDPOINT=https://s3.ru-1.storage.selcloud.ru
S3_REGION=ru-1
S3_BUCKET=yi-marketplace
S3_ACCESS_KEY=replace-from-selectel-console
S3_SECRET_KEY=replace-from-selectel-console
S3_PUBLIC_URL=https://s3.ru-1.storage.selcloud.ru/yi-marketplace

# === Telegram-бот ====================================================
# 1. Создайте бота через @BotFather в Telegram → получите токен
# 2. Узнайте свой chat_id через @userinfobot (для личного чата)
#    Для группового чата chat_id будет начинаться с минуса.
# 3. Если личный чат — напишите боту /start.
#    Если групповой — добавьте бота в группу и дайте админские права.
#
# ⚠️ ПОСЛЕ ДЕПЛОЯ ОБЯЗАТЕЛЬНО ОБНОВИТЕ ТОКЕН:
#    @BotFather → /revoke → выберите бота → /token → получите новый.
#    Старый перестанет работать. Вставьте новый в Vercel Env Variables.
#    Это нужно потому что текущий токен передавался через переписку с AI.
TELEGRAM_BOT_TOKEN=8533120323:AAFqwG2u86PkzoHahINNU0f6gEQT-eXyE0c
TELEGRAM_MANAGER_CHAT_ID=-5219385445

# === Яндекс.Метрика (опционально) ====================================
NEXT_PUBLIC_YANDEX_METRICA_ID=

# === Импорт товаров (только локально) ===============================
# Путь к Excel — нужен только для скрипта import-products.
PRODUCTS_XLSX_PATH=./data/мебель_1688.xlsx

# === Среда ===========================================================
NODE_ENV=development
